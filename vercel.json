{
  "version": 2,
  "builds": [
    {
      "src": "ecommerce-backend/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "ecommerce-backend/dist/**",
          "ecommerce-backend/images/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/images/(.*)",
      "dest": "ecommerce-backend/images/$1"
    },
    {
      "src": "/(.*)",
      "dest": "ecommerce-backend/server.js"
    }
  ]
}
